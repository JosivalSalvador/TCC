{
  "name": "ia",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install": "uv sync",
    "dev": "uv run --env-file .env fastapi dev src/main.py",
    "start": "uv run fastapi run src/main.py",
    "build": "echo 'Python não precisa de build'",
    "add": "uv add",
    "add:dev": "uv add --dev",
    "lint": "uv run ruff check . && uv run ruff format --check .",
    "lint:fix": "uv run ruff check --fix . && uv run ruff format .",
    "type-check": "echo 'Ignorando checagem de tipos do Python temporariamente'",
    "test": "uv run pytest",
    "precommit": "lint-staged",
    "ml:eda": "uv run --env-file .env python -m src.pipelines.01_eda",
    "ml:prep": "uv run --env-file .env python -m src.pipelines.02_pre_processa",
    "ml:train": "uv run --env-file .env python -m src.pipelines.03_treinamento",
    "ml:pipeline-full": "npm run ml:prep && npm run ml:train"
  },
  "lint-staged": {
    "*.py": [
      "uv run ruff check --fix",
      "uv run ruff format"
    ]
  }
}