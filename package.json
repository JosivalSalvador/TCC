{
  "name": "tcc",
  "version": "1.0.0",
  "packageManager": "npm@11.7.0",
  "private": true,
  "workspaces": [
    "web",
    "server",
    "ia"
  ],
  "scripts": {
    "prepare": "husky install",
    "install:all": "npm install && npm run install -w ia",
    "dev": "turbo run dev",
    "dev:web": "npm run dev -w web",
    "dev:server": "npm run dev -w server",
    "dev:ia": "npm run dev -w ia",
    "add:ia": "npm run add -w ia --",
    "add:ia:dev": "npm run add:dev -w ia --",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:gen": "npm run db:gen -w server",
    "db:migrate": "npm run db:migrate -w server",
    "db:studio": "npm run db:studio -w server",
    "db:seed": "npm run db:seed -w server",
    "db:deploy": "npm run db:deploy -w server",
    "db:deploy:prod": "npm run db:deploy:prod -w server",
    "db:reset": "npm run db:reset -w server",
    "db:format": "npm run db:format -w server",
    "test": "turbo run test",
    "test:e2e": "npm run test:e2e -w web",
    "test:e2e:ui": "npm run test:e2e:ui -w web",
    "test:e2e:report": "npm run test:e2e:report -w web",
    "test:e2e:codegen": "npm run test:e2e:codegen -w web"
  },
  "devDependencies": {
    "husky": "^8.0.0",
    "tinyexec": "^1.0.4",
    "turbo": "^2.8.20"
  },
  "overrides": {
    "@types/pg": "^8.16.0"
  }
}
